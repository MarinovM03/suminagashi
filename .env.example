# Firebase web config for the shared gallery (optional).
# Copy this file to ".env" and fill in the values from your Firebase project:
# Firebase console → Project settings → General → "Your apps" → SDK setup.
# These keys are safe to expose in the client; access is controlled by
# Firestore/Storage security rules (see the gallery section in README.md).
# Leave them blank and the app still runs — the gallery just stays disabled.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_APP_ID=
